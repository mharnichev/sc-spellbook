{
	email {$ACME_EMAIL}
	admin off
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

soulcuts.com.ua, www.soulcuts.com.ua {
	import security_headers
	encode zstd gzip

	redir /blog /blog/ 308

	@blog path /blog/*
	reverse_proxy @blog blog:3000

	reverse_proxy public-site:3000
}

admin.soulcuts.com.ua {
	import security_headers
	encode zstd gzip
	reverse_proxy admin-app:3000
}

api.soulcuts.com.ua {
	import security_headers
	encode zstd gzip
	reverse_proxy backend:8000
}
